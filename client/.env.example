# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Secret key — SERVER ONLY, bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---------- Stripe (payment gateway) ----------
STRIPE_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---------- AI Provider (anthropic | openai | mock) ----------
AI_PROVIDER=mock
AI_API_KEY=

# ---------- Backend API (server/) ----------
# Base URL of the server/ API. Local dev: http://localhost:4000
NEXT_PUBLIC_API_URL=https://bravestudio-backend.vercel.app
