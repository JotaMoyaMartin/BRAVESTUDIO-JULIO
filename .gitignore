# dependencies
node_modules/

# next.js (client)
.next/
out/

# builds
dist/
build/
tsconfig.tsbuildinfo

# env files — NEVER commit
.env
.env.local
.env*.local

# vercel
.vercel/

# logs
*.log
npm-debug.log*

# misc
.DS_Store
*.pem
.claude/
