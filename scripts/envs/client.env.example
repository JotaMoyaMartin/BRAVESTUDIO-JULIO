# BRÄVE Studio — client env values (source of truth for Vercel)
# Copy to: client/.env.production.local   (gitignored — never commit real values)
# Fill each value, then run: ./scripts/sync-vercel-env.sh client

# ── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# ── Backend API ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://bravestudio-backend.vercel.app

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxx
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ── App URL (frontend) ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://bravestudio-cleint.vercel.app

# ── AI provider ────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=sk-xxxxxxxx