# ============================================================
# BRÄVE Studio monorepo — root .gitignore (covers client/ + server/)
# ============================================================

# dependencies
node_modules/

# next.js (client)
.next/
out/

# builds
dist/
build/
tsconfig.tsbuildinfo

# env files — NEVER commit
.env
.env.local
.env*.local

# vercel
.vercel/

# logs
*.log
npm-debug.log*

# misc
.DS_Store
*.pem
.claude/
.vercel
.env*

# vercel env source-of-truth values (secrets) — used by scripts/sync-vercel-env.sh
# The example templates (*.env.example) ARE committed; real value files are not.
.env.production.local
.env.development.local
.env.preview.local
scripts/envs/*.env
!scripts/envs/*.env.example
