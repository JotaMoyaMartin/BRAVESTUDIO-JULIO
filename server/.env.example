# ---------- Server ----------
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed origins for CORS (the client app).
CORS_ORIGIN=http://localhost:3000

# ---------- Supabase ----------
# Same project as the client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx

# Secret key — bypasses Row Level Security. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
