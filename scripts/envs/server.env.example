# BRÄVE Studio — server env values (source of truth for Vercel)
# Copy to: server/.env.production.local   (gitignored — never commit real values)
# Fill each value, then run: ./scripts/sync-vercel-env.sh server

# ── Supabase (same values as client) ───────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# ── CORS (frontend origin) ────────────────────────────────
CORS_ORIGIN=https://bravestudio-cleint.vercel.app